generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  password      String?
  createdAt     DateTime @default(now())
  savedColleges SavedCollege[]
}

model College {
  id            String   @id @default(cuid())
  name          String
  location      String
  city          String
  state         String
  type          String   // "Government" | "Private" | "Deemed"
  fees          Int      // annual fees in INR
  rating        Float
  totalRatings  Int      @default(0)
  established   Int
  imageUrl      String?
  description   String
  nirf          Int?     // NIRF ranking
  naac          String?  // NAAC grade A++/A+/A/B++
  courses       Course[]
  placements    Placement?
  savedBy       SavedCollege[]
  createdAt     DateTime @default(now())
}

model Course {
  id         String  @id @default(cuid())
  name       String
  duration   Int     // years
  fees       Int
  seats      Int
  college    College @relation(fields: [collegeId], references: [id])
  collegeId  String
}

model Placement {
  id             String  @id @default(cuid())
  avgPackage     Int     // LPA in thousands
  highestPackage Int
  placementRate  Int     // percentage
  topRecruiters  String  // comma separated
  college        College @relation(fields: [collegeId], references: [id])
  collegeId      String  @unique
}

model SavedCollege {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  college   College  @relation(fields: [collegeId], references: [id])
  collegeId String
  savedAt   DateTime @default(now())

  @@unique([userId, collegeId])
}